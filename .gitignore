# ==================== 编译工具 ====================
# 忽略本地编译环境 (包含 JDK, Gradle, Android SDK 等，体积较大)
tools/

# ==================== 构建缓存与临时文件 ====================
# 忽略 Gradle 和 Kotlin 编译产生的缓存目录
build-temp/
kotlin-temp/
.gradle-home/

# ==================== IDE 配置 ====================
# 忽略 IntelliJ IDEA 相关文件
.idea/
*.iml

# ==================== 本地配置 ====================
# 忽略本地 SDK 路径配置文件
local.properties

# ==================== 系统文件 ====================
# 忽略 macOS 和 Windows 系统生成的文件
.DS_Store
Thumbs.db

# ==================== 输出文件 ====================
# 忽略=打包生成的 APK 安装包
*.apk
# 忽略构建日志
build.log

# ==================== 签名文件 ====================
# 说明：以下文件包含敏感信息，仅用于本地编译，严禁上传到 GitHub

# 密钥库文件
signing/*.jks

# 签名配置文件
signing.properties

# 签名备份目录
Voice-main/signing/backup/
